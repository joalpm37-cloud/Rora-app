ails/builder\n\nSource: default | Team: emails","inputSchema":{"required":["body_locationId","body_type","body_importProvider"],"type":"object","properties":{"body_name":{"description":"name","type":"string","example":"Template1"},"body_builderVersion":{"type":"string","enum":["1","2"],"description":"builderVersion"},"body_locationId":{"example":"ve9EPM428h8vShlRW1KT","description":"locationId","type":"string"},"body_templateDataUrl":{"type":"string","description":"templateDataUrl","example":""},"body_importURL":{"type":"string","example":"https://tplshare.com/fhYJ3Mi","description":"importURL"},"body_templateSource":{"example":"template_library","type":"string","description":"templateSource"},"body_parentId":{"description":"parentId","type":"string","example":"zYy3YOUuHxgomU1uYJty"},"body_updatedBy":{"example":"zYy3YOUuHxgomU1uYJty","description":"updatedBy","type":"string"},"body_isPlainText":{"description":"isPlainText","type":"boolean","example":false},"body_importProvider":{"description":"importProvider","type":"string","enum":["mailchimp","active_campaign","kajabi"]},"body_type":{"type":"string","description":"type","enum":["html","folder","import","builder","blank"]},"body_title":{"type":"string","example":"template title","description":"title"}}}},{"name":"blogs_update-blog-post","description":"Modifies an existing blog post including content, metadata, categories, tags, and publication settings. Can update title, description, HTML content, featured image, status, SEO fields (URL slug, canonical link), categories, tags, author, and scheduling information. Returns the updated blog post with modified fields. Use this tool when users want to edit a blog post, update article content, modify blog entry, change blog post details, or revise published content. Ideal for content editing, article updates, blog maintenance, and content revision workflows.\n\nCapabilities: update_update-blog-post\n\nExamples:\n- Use this tool to update blog post\n- Endpoint: /blogs/posts/{postId}\n\nSource: default | Team: blogs","inputSchema":{"required":["body_title","body_locationId","body_blogId","body_imageUrl","body_description","body_rawHTML","body_status","body_imageAltText","body_categories","body_author","body_urlSlug","body_publishedAt"],"type":"object","properties":{"body_imageUrl":{"type":"string","example":"Image URl","description":"imageUrl"},"body_urlSlug":{"example":"any-blog-post-url","description":"urlSlug","type":"string"},"body_blogId":{"description":"You can find the blog id from blog site dashboard link","example":"Blog ID","type":"string"},"body_title":{"type":"string","description":"title","example":"Your blog title"},"body_tags":{"example":["blog","seo"],"description":"tags","items":{"type":"string"},"type":"array"},"body_locationId":{"example":"Location ID","type":"string","description":"locationId"},"body_categories":{"description":"This needs to be array of category ids, which you can get from the category get api call.","items":{"type":"string"},"type":"array","example":["9c48df2694a849b6089f9d0d3513efe","6683abde331c041f32c07aee"]},"body_imageAltText":{"type":"string","example":"Alt text for your blog image","description":"imageAltText"},"body_author":{"description":"This needs to be author id, which you can get from the author get api call.","example":"6683abde331c041f32c07aea","type":"string"},"body_publishedAt":{"description":"Provide ISO timestamp","type":"string","example":"2025-02-05T18:30:47.000Z"},"body_rawHTML":{"type":"string","description":"rawHTML","example":"<h1>Your blog content</h1>"},"body_canonicalLink":{"example":"https://tryghl.blog/post/testing-unsplash","type":"string","description":"canonicalLink"},"body_status":{"example":"PUBLISHED","description":"status","enum":["DRAFT","PUBLISHED","SCHEDULED","ARCHIVED"],"type":"string"},"body_description":{"example":"A short description","type":"string","description":"description"}}}}]},"jsonrpc":"2.0","id":1776059404711}

