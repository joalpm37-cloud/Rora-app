event: message
data: {"result":{"tools":[{"name":"social-media-posting_edit-post","description":"Modifies an existing social media post including content, media, scheduling, and platform-specific settings. Can update post summary, media files, schedule date, tags, categories, approval details, and platform configurations. Returns the updated post with modified fields. Use this tool when users want to edit social media post, update post content, modify scheduled post, change post details, or revise social media content. Ideal for post editing, content updates, schedule changes, and social media post modification.\n\nCapabilities: edit-post\n\nExamples:\n- Use this tool to edit post\n- Endpoint: /social-media-posting/{locationId}/posts/{id}\n\nSource: default | Team: social-media-posting","inputSchema":{"properties":{"body_tiktokPostDetails":{"description":"Tiktok Post Details","type":"string"},"body_media":{"items":{"type":"object"},"type":"array","description":"Post Media Data \n The limitations of media as per the platforms is provided through the reference link in API description"},"body_status":{"type":"object","example":"draft","description":"Status must be one of the following values: in_progress, draft, failed, published, scheduled, in_review, notification_sent, deleted"},"path_id":{"description":"Post Id","example":"65fac446d599990d1313c1dd","type":"string"},"body_categoryId":{"description":"Category Id","type":"string"},"path_locationId":{"example":"ve9EPM428h8vShlRW1KT","description":"Location Id","type":"string"},"body_postApprovalDetails":{"description":"Post Approval Details","type":"string"},"body_gmbPostDetails":{"description":"GMB Post Details","type":"string"},"body_followUpComment":{"type":"string","description":"Follow Up Comment on platform. It is not allowed on Tiktok and GMB accounts and there is a limit of 280 charecters for twitter account","example":"First comment"},"body_scheduleDate":{"type":"string","description":"Schedule Date"},"body_type":{"description":"Post Type must be one of the following values: - post, story, reel","example":"post","type":"object"},"body_scheduleTimeUpdated":{"description":"if schedule datetime is updated","example":true,"type":"boolean"},"body_createdBy":{"description":"Created By","type":"string"},"body_accountIds":{"type":"array","example":["aF3KhyL8JIuBwzK3m7Ly_iVrVJ2uoXNF0wzcBzgl5_12554616564525983496"],"description":"Account Ids","items":{"type":"string"}},"body_userId":{"type":"string","description":"User ID","example":"sdfdsfdsfEWEsdfsdsW32dd"},"body_tags":{"description":"Array of Tag Value","items":{"type":"string"},"type":"array","example":["Tag1"]},"body_ogTagsDetails":{"description":"Og Tags Meta Data","type":"string"},"body_summary":{"example":"Hello World","description":"Post Content \n The limitations of content as per the platforms is provided through the reference link in API description","type":"string"}},"type":"object","required":["path_locationId","path_id","body_type"]}},{"name":"contacts_update-contact","description":"Modifies existing contact information in the CRM. Can update any contact property including name, email, phone number, address, tags, custom fields, and company details. Updates only the provided fields while preserving all other existing contact data. Returns the updated contact record with modified fields. Use this tool when users want to edit contact information, update contact details, change contact data, modify a contact record, or correct contact information. Ideal for contact maintenance, data correction, and contact information updates.\n\nCapabilities: update_update-contact\n\nExamples:\n- Use this tool to update contact\n- Endpoint: /contacts/{contactId}\n\nSource: default | Team: contacts","inputSchema":{"required":["path_contactId"],"properties":{"body_email":{"type":"string","example":"rosan@deos.com","nullable":true,"description":"email"},"body_assignedTo":{"nullable":true,"type":"string","description":"User's Id","example":"y0BeYjuRIlDwsDcOHOJo"},"body_postalCode":{"example":"35061","type":"string","description":"postalCode"},"body_timezone":{"example":"America/Chihuahua","nullable":true,"description":"timezone","type":"string"},"body_lastName":{"example":"Deo","nullable":true,"description":"lastName","type":"string"},"body_firstName":{"example":"rosan","type":"string","nullable":true,"description":"firstName"},"body_state":{"nullable":true,"type":"string","example":"AL","description":"state"},"body_source":{"type":"string","nullable":true,"description":"source","example":"public api"},"body_country":{"description":"country","example":"US","type":"string"},"body_tags":{"description":"This field will overwrite all current tags associated with the contact. To update a tags, it is recommended to use the Add Tag or Remove Tag API instead.","example":["nisi sint commodo amet","consequat"],"items":{"type":"string"},"type":"array"},"body_phone":{"example":"+1 888-888-8888","description":"phone","nullable":true,"type":"string"},"body_website":{"description":"website","type":"string","example":"https://www.tesla.com","nullable":true},"body_dnd":{"example":true,"description":"dnd","type":"boolean"},"path_contactId":{"example":"ocQHyuzHvysMo5N5VsXc","description":"Contact Id","type":"string"},"body_city":{"description":"city","type":"string","example":"Dolomite","nullable":true},"body_dndSettings":{"description":"dndSettings","type":"object"},"body_name":{"example":"rosan Deo","nullable":true,"description":"name","type":"string"},"body_inboundDndSettings":{"description":"inboundDndSettings","type":"object"},"body_address1":{"type":"string","description":"address1","example":"3535 1st St N","nullable":true},"body_customFields":{"description":"customFields","items":{"type":"string"},"type":"array"}},"type":"object"}},{"name":"opportunities_get-opportunity","description":"Retrieves detailed information for a specific opportunity by opportunity ID. Returns complete opportunity details including name, monetary value, pipeline and stage information, status, assigned user, contact details, custom fields, notes, tasks, and calendar events. Use this tool when users want to get opportunity details, view opportunity, see deal information, retrieve opportunity data, or look up opportunity by ID. Ideal for opportunity detail viewing, deal information retrieval, and opportunity data lookup.\n\nCapabilities: get_get-opportunity\n\nExamples:\n- Use this tool to get opportunity\n- Endpoint: /opportunities/{id}\n\nSource: default | Team: opportunities","inputSchema":{"type":"object","required":["path_id"],"properties":{"path_id":{"example":"yWQobCRIhRguQtD2llvk","description":"Opportunity Id","type":"string"}}}},{"name":"locations_get-location","description":"Retrieves detailed information for a sub-account (formerly location) by location ID. Returns complete location details including name, domain, address, business information, social media links, settings, company ID, contact information, and logo URL. Use this tool when users want to get location details, view location information, see sub-account details, retrieve location data, or look up location by ID. Ideal for location information retrieval, sub-account detail viewing, and location data lookup.\n\nCapabilities: get_get-location\n\nExamples:\n- Use this tool to get sub-account (formerly location)\n- Endpoint: /locations/{locationId}\n\nSource: default | Team: locations","inputSchema":{"properties":{"path_locationId":{"example":"ve9EPM428h8vShlRW1KT","type":"string","description":"Location Id"}},"type":"object","required":["path_locationId"]}},{"name":"contacts_get-all-tasks","description":"Retrieves all tasks associated with a specific contact. Returns a list of tasks including title, description, body, due date, completion status, assigned user, and task ID. Shows both completed and pending tasks for the contact. Use this tool when users want to view contact tasks, see tasks for a contact, get contact task list, check contact to-dos, or list tasks assigned to a contact. Ideal for task management, contact task tracking, follow-up management, and contact activity review.\n\nCapabilities: get_get-all-tasks\n\nExamples:\n- Use this tool to get all tasks\n- Endpoint: /contacts/{contactId}/tasks\n\nSource: default | Team: contacts","inputSchema":{"properties":{"path_contactId":{"description":"Contact Id","example":"sx6wyHhbFdRXh302LLNR","type":"string"}},"type":"object","required":["path_contactId"]}},{"name":"conversations_send-a-new-message","description":"Sends a new message to a contact through various channels including SMS, Email, WhatsApp, Instagram, Facebook, Custom, or Live Chat. Supports text messages, HTML email content, attachments, email CC/BCC, reply threading, template usage, and message scheduling. Returns conversation ID, message ID, and email message ID for threaded replies. Use this tool when users want to send a message, send SMS, send email, send WhatsApp message, reply to conversation, or schedule a message. Ideal for message sending, communication workflows, customer messaging, and multi-channel communication.\n\nCapabilities: send-a-new-message\n\nExamples:\n- Use this tool to send a new message\n- Endpoint: /conversations/messages\n\nSource: default | Team: conversations","inputSchema":{"type":"object","properties":{"body_message":{"description":"Text content of the message","example":"Hello, how can I help you today?","type":"string"},"body_toNumber":{"example":"+1439499299","type":"string","description":"Recipient phone number for outbound messages"},"body_emailTo":{"example":"recipient@company.com","type":"string","description":"Email address to send to, if different from contact's primary email. This should be a valid email address associated with the contact."},"body_replyMessageId":{"description":"ID of message being replied to","example":"msg123","type":"string"},"body_fromNumber":{"example":"+1499499299","description":"Phone number used as the sender number for outbound messages","type":"string"},"body_scheduledTimestamp":{"type":"number","example":1669287863,"description":"UTC Timestamp (in seconds) at which the message should be scheduled"},"body_html":{"description":"HTML content of the message","example":"<p>Hello World</p>","type":"string"},"body_emailBcc":{"example":["bcc1@company.com","bcc2@company.com"],"description":"Array of BCC email addresses","items":{"type":"string"},"type":"array"},"body_emailCc":{"example":["cc1@company.com","cc2@company.com"],"items":{"type":"string"},"type":"array","description":"Array of CC email addresses"},"body_type":{"enum":["SMS","Email","WhatsApp","IG","FB","Custom","Live_Chat"],"example":"Email","type":"string","description":"Type of message being sent"},"body_conversationProviderId":{"type":"string","example":"provider123","description":"ID of conversation provider"},"body_emailReplyMode":{"example":"reply_all","enum":["reply","reply_all"],"description":"Mode for email replies","type":"string"},"body_appointmentId":{"type":"string","description":"ID of the associated appointment","example":"appt123"},"body_subject":{"description":"Subject line for email messages","type":"string","example":"Important Update"},"body_contactId":{"type":"string","description":"ID of the contact receiving the message","example":"abc123def456"},"body_templateId":{"description":"ID of message template","example":"template123","type":"string"},"body_emailFrom":{"description":"Email address to send from","example":"sender@company.com","type":"string"},"body_threadId":{"type":"string","example":"thread123","description":"ID of message thread. For email messages, this is the message ID that contains multiple email messages in the thread"},"body_attachments":{"description":"Array of attachment URLs","type":"array","example":["https://storage.com/file1.pdf","https://storage.com/file2.jpg"],"items":{"type":"string"}}},"required":["body_type","body_contactId"]}},{"name":"blogs_check-url-slug-exists","description":"Validates whether a URL slug is available for a blog post before publishing. Checks if the slug already exists for other posts, optionally excluding a specific post ID. Returns a boolean indicating slug availability. Use this tool when users want to check if a URL slug is available, validate blog post slug, verify slug uniqueness, or check slug before publishing. Ideal for slug validation, URL slug checking, and pre-publication validation workflows.\n\nCapabilities: check-url-slug-exists\n\nExamples:\n- Use this tool to check url slug\n- Endpoint: /blogs/posts/url-slug-exists\n\nSource: default | Team: blogs","inputSchema":{"properties":{"query_locationId":{"type":"string","description":"query_locationId","example":"ve9EPM428h8vShlRW1KT"},"query_postId":{"type":"string","example":"66f429b8afdce84227a4610d","description":"query_postId"},"query_urlSlug":{"description":"query_urlSlug","type":"string"}},"type":"object","required":["query_urlSlug","query_locationId"]}},{"name":"contacts_get-contact","description":"Retrieves detailed contact information by contact ID. Returns complete contact profile including personal details (name, email, phone), address information, tags, custom fields, and associated opportunities. Use this tool when users want to look up a specific contact, view contact details, get contact information, or fetch a contact profile. Ideal for scenarios where the contact ID is known and full contact information is needed.\n\nCapabilities: get_get-contact\n\nExamples:\n- Use this tool to get contact\n- Endpoint: /contacts/{contactId}\n\nSource: default | Team: contacts","inputSchema":{"properties":{"path_contactId":{"example":"ocQHyuzHvysMo5N5VsXc","type":"string","description":"Contact Id"}},"type":"object","required":["path_contactId"]}},{"name":"conversations_get-messages","description":"Retrieves messages from a specific conversation with optional filtering by message type. Supports filtering by message types (SMS, Email, Call, Facebook, Instagram, WhatsApp, etc.) and pagination using lastMessageId and limit. Returns a list of messages with body, direction, status, attachments, metadata, and timestamps. Use this tool when users want to view conversation messages, get message history, see conversation thread, retrieve messages from a conversation, or read conversation messages. Ideal for message viewing, conversation history review, and message thread retrieval.\n\nCapabilities: get_get-messages\n\nExamples:\n- Use this tool to get messages by conversation id\n- Endpoint: /conversations/{conversationId}/messages\n\nSource: default | Team: conversations","inputSchema":{"properties":{"query_type":{"description":"Types of message to fetched separated with comma","type":"string","example":"TYPE_SMS,TYPE_CALL","enum":["TYPE_CALL","TYPE_SMS","TYPE_EMAIL","TYPE_FACEBOOK","TYPE_GMB","TYPE_INSTAGRAM","TYPE_WHATSAPP","TYPE_ACTIVITY_APPOINTMENT","TYPE_ACTIVITY_CONTACT","TYPE_ACTIVITY_INVOICE","TYPE_ACTIVITY_PAYMENT","TYPE_ACTIVITY_OPPORTUNITY","TYPE_LIVE_CHAT","TYPE_INTERNAL_COMMENTS"]},"query_lastMessageId":{"example":"tDtDnQdgm2LXpyiqYvZ6","description":"Message ID of the last message in the list as a string","type":"string"},"query_limit":{"example":20,"description":"Number of messages to be fetched from the conversation. Default limit is 20","type":"number"},"path_conversationId":{"type":"string","example":"tDtDnQdgm2LXpyiqYvZ6","description":"Conversation ID as string"}},"required":["path_conversationId"],"type":"object"}},{"name":"opportunities_update-opportunity","description":"Modifies an existing opportunity in the sales pipeline. Can update opportunity name, pipeline, pipeline stage, status, monetary value, assigned user, and custom fields. Returns the updated opportunity with modified fields. Use this tool when users want to update opportunity, edit deal, change opportunity status, modify opportunity value, move opportunity to different stage, or update deal information. Ideal for opportunity management, deal updates, pipeline stage changes, and opportunity modification workflows.\n\nCapabilities: update_update-opportunity\n\nExamples:\n- Use this tool to update opportunity\n- Endpoint: /opportunities/{id}\n\nSource: default | Team: opportunities","inputSchema":{"type":"object","properties":{"body_status":{"description":"status","enum":["open","won","lost","abandoned","all"],"type":"string"},"body_name":{"description":"name","example":"First Opps","type":"string"},"body_customFields":{"description":"Update custom fields to opportunities.","type":"array","items":{"type":"string"}},"body_pipelineStageId":{"type":"string","description":"pipelineStageId","example":"7915dedc-8f18-44d5-8bc3-77c04e994a10"},"body_assignedTo":{"example":"082goXVW3lIExEQPOnd3","description":"assignedTo","type":"string"},"body_monetaryValue":{"description":"monetaryValue","example":220,"type":"number"},"body_pipelineId":{"example":"bCkKGpDsyPP4peuKowkG","description":"pipeline Id","type":"string"},"path_id":{"description":"Opportunity Id","type":"string","example":"yWQobCRIhRguQtD2llvk"}},"required":["path_id"]}},{"name":"blogs_get-blog-post","description":"Retrieves blog posts for a specific blog site using blog ID with filtering and pagination. Supports filtering by publication status (published, scheduled, archived, draft), search terms for post name, and pagination with limit and offset. Returns a list of blog posts with title, description, content, image, categories, tags, author, publication date, and status. Use this tool when users want to get blog posts, list articles, find blog posts by status, search blog content, or retrieve published articles. Ideal for blog post listing, content management, article retrieval, and blog content browsing.\n\nCapabilities: get_get-blog-post\n\nExamples:\n- Use this tool to get blog posts by blog id\n- Endpoint: /blogs/posts/all\n\nSource: default | Team: blogs","inputSchema":{"required":["query_locationId","query_blogId","query_limit","query_offset"],"type":"object","properties":{"query_searchTerm":{"description":"search for any post by name","example":"ai news","type":"string"},"query_blogId":{"type":"string","example":"66f429b8afdce84227a4610d","description":"query_blogId"},"query_locationId":{"example":"ve9EPM428h8vShlRW1KT","type":"string","description":"query_locationId"},"query_offset":{"type":"number","example":0,"description":"query_offset"},"query_limit":{"example":4,"description":"query_limit","type":"number"},"query_status":{"example":"PUBLISHED","description":"query_status","enum":["PUBLISHED","SCHEDULED","ARCHIVED","DRAFT"],"type":"string"}}}},{"name":"blogs_get-all-categories-by-location","description":"Retrieves all blog categories for a specific location with pagination support. Returns a list of categories including category ID, label, location ID, URL slug, and canonical link. Supports pagination with limit and offset parameters. Use this tool when users want to get blog categories, list categories, find available categories, or retrieve category information. Ideal for category selection, category management, and blog category lookup scenarios.\n\nCapabilities: get_get-all-categories-by-location\n\nExamples:\n- Use this tool to get all categories\n- Endpoint: /blogs/categories\n\nSource: default | Team: blogs","inputSchema":{"required":["query_locationId","query_limit","query_offset"],"properties":{"query_offset":{"description":"Number of categories to skip in listing","type":"number"},"query_limit":{"type":"number","description":"Number of categories to show in the listing"},"query_locationId":{"description":"query_locationId","example":"ve9EPM428h8vShlRW1KT","type":"string"}},"type":"object"}},{"name":"locations_get-custom-fields","description":"Retrieves custom fields for a location with optional filtering by model type. Supports filtering by model (contact, opportunity, or all) to retrieve custom fields for specific entity types. Returns custom field list including field ID, name, field key, data type, placeholder, position, picklist options, and field settings. Use this tool when users want to get custom fields, list custom fields, find available custom fields, retrieve field definitions, or view custom field configuration. Ideal for custom field management, field discovery, and custom field configuration lookup.\n\nCapabilities: get_get-custom-fields\n\nExamples:\n- Use this tool to get custom fields\n- Endpoint: /locations/{locationId}/customFields\n\nSource: default | Team: locations","inputSchema":{"required":["path_locationId"],"properties":{"query_model":{"example":"opportunity","enum":["contact","opportunity","all"],"description":"Model of the custom field you want to retrieve","type":"string"},"path_locationId":{"example":"ve9EPM428h8vShlRW1KT","description":"Location Id","type":"string"}},"type":"object"}},{"name":"opportunities_get-pipelines","description":"Retrieves all sales pipelines for a location. Returns pipeline list including pipeline ID, name, stages, visibility settings (funnel and pie chart), and location ID. Use this tool when users want to get pipelines, list sales pipelines, find available pipelines, or retrieve pipeline information. Ideal for pipeline selection, pipeline management, and pipeline discovery scenarios.\n\nCapabilities: get_get-pipelines\n\nExamples:\n- Use this tool to get pipelines\n- Endpoint: /opportunities/pipelines\n\nSource: default | Team: opportunities","inputSchema":{"properties":{"query_locationId":{"example":"ve9EPM428h8vShlRW1KT","type":"string","description":"query_locationId"}},"required":["query_locationId"],"type":"object"}},{"name":"blogs_create-blog-post","description":"Creates a new blog post for a blog site with comprehensive content and metadata. Accepts blog post details including title, description, HTML content, featured image, categories, tags, author assignment, URL slug, canonical link, and publication timestamp. Supports status management (draft, published, scheduled, archived) and SEO optimization settings. Returns the created blog post with assigned ID and metadata. Use this tool when users want to create a blog post, publish an article, add blog content, write a blog entry, or create new blog content. Ideal for content creation workflows, blog publishing, article management, and content marketing.\n\nCapabilities: create_create-blog-post\n\nExamples:\n- Use this tool to create blog post\n- Endpoint: /blogs/posts\n\nSource: default | Team: blogs","inputSchema":{"properties":{"body_status":{"description":"status","type":"string","example":"This can be PUBLISHED OR SCHEDULED OR ARCHIVED OR DRAFT","enum":["DRAFT","PUBLISHED","SCHEDULED","ARCHIVED"]},"body_tags":{"example":["blog","seo"],"items":{"type":"string"},"description":"tags","type":"array"},"body_imageAltText":{"description":"imageAltText","type":"string","example":"Alt text for your blog image"},"body_title":{"example":"Your blog title","description":"title","type":"string"},"body_locationId":{"example":"Location ID","type":"string","description":"locationId"},"body_blogId":{"example":"Blog ID","description":"You can find the blog id from blog site dashboard link","type":"string"},"body_imageUrl":{"example":"Image URl","description":"imageUrl","type":"string"},"body_categories":{"description":"This needs to be array of category ids, which you can get from the category get api call.","items":{"type":"string"},"example":["9c48df2694a849b6089f9d0d3513efe","6683abde331c041f32c07aee"],"type":"array"},"body_author":{"example":"6683abde331c041f32c07aea","description":"This needs to be author id, which you can get from the author get api call.","type":"string"},"body_rawHTML":{"example":"<h1>Your blog content</h1>","description":"rawHTML","type":"string"},"body_publishedAt":{"type":"string","example":"2025-02-05T18:30:47.000Z","description":"Provide ISO timestamp"},"body_canonicalLink":{"description":"canonicalLink","example":"https://tryghl.blog/post/testing-unsplash","type":"string"},"body_description":{"description":"description","example":"A short description","type":"string"},"body_urlSlug":{"description":"urlSlug","type":"string","example":"any-blog-post-url"}},"type":"object","required":["body_title","body_locationId","body_blogId","body_imageUrl","body_description","body_rawHTML","body_status","body_imageAltText","body_categories","body_author","body_urlSlug","body_publishedAt"]}},{"name":"social-media-posting_create-post","description":"Creates a new social media post for multiple platforms. Supports posting to Facebook, Instagram, Twitter, LinkedIn, Google My Business, and TikTok with platform-specific content and media. Accepts post content, media files, scheduling information, tags, categories. Returns the created post with post ID and status. Use this tool when users want to create social media post, publish post, schedule social media content, post to multiple platforms, or create social media content. Ideal for social media content creation, multi-platform posting, content scheduling, and social media management.\n\nCapabilities: create_create-post\n\nExamples:\n- Use this tool to create post\n- Endpoint: /social-media-posting/{locationId}/posts\n\nSource: default | Team: social-media-posting","inputSchema":{"type":"object","properties":{"path_locationId":{"type":"string","description":"Location Id param for api endpoint","example":"ve9EPM428h8vShlRW1KT"},"body_accountIds":{"type":"array","items":{"type":"string"},"description":"Choose the available accountId or prefer most recent accountId if found multiple","example":["aF3KhyL8JIuBwzK3m7Ly_iVrVJ2uoXNF0wzcBzgl5_12554616564525983496"]},"body_summary":{"type":"string","description":"The post content goes here","example":"Hello World"},"body_media":{"type":"array","items":{"type":"object"},"description":"Post Media Data \n The limitations of media as per the platforms is provided through the reference link in API description"},"body_status":{"type":"string","description":"Status must be one of the following values: null, in_progress, draft, failed, published, scheduled, in_review, notification_sent, deleted","example":"draft"},"body_scheduleDate":{"type":"string","description":"Schedule Date"},"body_createdBy":{"type":"string","description":"Created By"},"body_followUpComment":{"type":"string","description":"Follow Up Comment on platform. It is not allowed on Tiktok and GMB accounts and there is a limit of 280 charecters for twitter account","example":"First comment"},"body_type":{"type":"string","description":"Post Type must be one of the following values: - post, story, reel","example":"post"},"body_scheduleTimeUpdated":{"type":"boolean","description":"if schedule datetime is updated","example":true},"body_tags":{"type":"array","items":{"type":"string"},"description":"Array of Tag Value","example":["65f151c99bc2bf3aaf970d72"]},"body_categoryId":{"type":"string","description":"Category Id","example":"65f151c99bc2bf3aaf970d72"},"body_userId":{"type":"string","description":"User ID","example":"sdfdsfdsfEWEsdfsdsW32dd"}},"required":["body_accountIds","body_type","body_userId","body_status"]}},{"name":"contacts_add-tags","description":"Adds one or more tags to an existing contact record. Appends the new tags to the contact's current tag list without removing any existing tags, allowing incremental tag assignment. Returns the updated contact with the complete tag list including newly added tags. Use this tool when users want to add tags to a contact, tag a contact, categorize a contact, label a contact, or assign tags to a contact record. Ideal for contact organization, contact categorization, tag management, and contact labeling workflows.\n\nCapabilities: add_add-tags\n\nExamples:\n- Use this tool to add tags\n- Endpoint: /contacts/{contactId}/tags\n\nSource: default | Team: contacts","inputSchema":{"properties":{"path_contactId":{"example":"sx6wyHhbFdRXh302LLNR","description":"Contact Id","type":"string"},"body_tags":{"description":"tags","example":["minim","velit magna"],"items":{"type":"string"},"type":"array"}},"required":["path_contactId","body_tags"],"type":"object"}},{"name":"social-media-posting_get-post","description":"Retrieves detailed information for a specific social media post by post ID. Returns complete post details including content, media, status, schedule information, platform accounts, tags, categories, and post metadata. Use this tool when users want to get post details, view social media post, see post information, retrieve post data, or look up post by ID. Ideal for post detail viewing, post information retrieval, and post data lookup.\n\nCapabilities: get_get-post\n\nExamples:\n- Use this tool to get post\n- Endpoint: /social-media-posting/{locationId}/posts/{id}\n\nSource: default | Team: social-media-posting","inputSchema":{"required":["path_locationId","path_id"],"properties":{"path_locationId":{"example":"ve9EPM428h8vShlRW1KT","description":"Location Id","type":"string"},"path_id":{"example":"65fac446d599990d1313c1dd","type":"string","description":"Post Id"}},"type":"object"}},{"name":"calendars_get-calendar-events","description":"Retrieves calendar events and appointments within a specified time range. Filters events by user ID, group ID, or calendar ID to show appointments for specific team members or calendars. Returns appointment details including participants, date and time, duration, status, location, notes, recurring event information, and assigned resources. Use this tool when users want to view calendar events, check appointments, see scheduled meetings, get calendar schedule, find appointments in a date range, or view team calendar. Ideal for calendar viewing, appointment lookup, schedule checking, and availability queries.\n\nCapabilities: get_get-calendar-events\n\nExamples:\n- Use this tool to get calendar events\n- Endpoint: /calendars/events\n\nSource: default | Team: calendars","inputSchema":{"type":"object","required":["query_locationId","query_startTime","query_endTime"],"properties":{"query_locationId":{"description":"Location Id","example":"0007BWpSzSwfiuSl0tR2","type":"string"},"query_calendarId":{"example":"BqTwX8QFwXzpegMve9EQ","description":"Either of calendarId, userId or groupId is required","type":"string"},"query_userId":{"description":"User Id - Owner of an appointment. Either of userId, groupId or calendarId is required","example":"CVokAlI8fgw4WYWoCtQz","type":"string"},"query_startTime":{"example":"1680373800000","description":"Start Time (in millis)","type":"string"},"query_groupId":{"type":"string","example":"ocQHyuzHvysMo5N5VsXc","description":"Either of groupId, calendarId or userId is required"},"query_endTime":{"type":"string","description":"End Time (in millis)","example":"1680978599999"}}}},{"name":"contacts_create-contact","description":"Creates a new contact record in the CRM with personal and business information. Accepts contact details including name, email, phone number, address, company information, tags, custom fields, and assigned user. Returns the newly created contact with assigned ID and timestamps. Use this tool when users want to add a new contact, create a contact record, register a new lead, or save contact information. Ideal for contact creation workflows, lead capture, and contact management scenarios.\n\nCapabilities: create_create-contact\n\nExamples:\n- Use this tool to create contact\n- Endpoint: /contacts/\n\nSource: default | Team: contacts","inputSchema":{"required":["body_locationId"],"type":"object","properties":{"body_inboundDndSettings":{"type":"object","description":"inboundDndSettings"},"body_locationId":{"description":"locationId","type":"string","example":"ve9EPM428h8vShlRW1KT"},"body_source":{"description":"source","example":"public api","type":"string"},"body_dndSettings":{"type":"object","description":"dndSettings"},"body_website":{"nullable":true,"example":"https://www.tesla.com","description":"website","type":"string"},"body_firstName":{"example":"Rosan","nullable":true,"description":"firstName","type":"string"},"body_timezone":{"description":"timezone","nullable":true,"example":"America/Chihuahua","type":"string"},"body_companyName":{"description":"companyName","nullable":true,"example":"DGS VolMAX","type":"string"},"body_address1":{"example":"3535 1st St N","nullable":true,"description":"address1","type":"string"},"body_state":{"example":"AL","nullable":true,"description":"state","type":"string"},"body_assignedTo":{"example":"y0BeYjuRIlDwsDcOHOJo","type":"string","description":"User's Id"},"body_phone":{"example":"+1 888-888-8888","nullable":true,"description":"phone","type":"string"},"body_name":{"example":"Rosan Deo","nullable":true,"description":"name","type":"string"},"body_email":{"nullable":true,"description":"email","example":"rosan@deos.com","type":"string"},"body_lastName":{"type":"string","nullable":true,"description":"lastName","example":"Deo"},"body_city":{"nullable":true,"example":"Dolomite","description":"city","type":"string"},"body_tags":{"description":"tags","example":["nisi sint commodo amet","consequat"],"items":{"type":"string"},"type":"array"},"body_dnd":{"example":true,"type":"boolean","description":"dnd"},"body_postalCode":{"type":"string","example":"35061","description":"postalCode"},"body_customFields":{"items":{"type":"string"},"description":"customFields","type":"array"},"body_gender":{"type":"string","example":"male","description":"gender"},"body_country":{"example":"US","description":"country","type":"string"}}}},{"name":"social-media-posting_get-account","description":"Retrieves a list of connected social media accounts and groups for a location. Returns account information including account IDs, platform types, and group associations. Use this tool when users want to get social media accounts, list connected accounts, find available accounts, or retrieve account information. Ideal for account selection, account management, and social media account discovery.\n\nCapabilities: get_get-account\n\nExamples:\n- Use this tool to get accounts\n- Endpoint: /social-media-posting/{locationId}/accounts\n\nSource: default | Team: social-media-posting","inputSchema":{"type":"object","properties":{"path_locationId":{"example":"ve9EPM428h8vShlRW1KT","type":"string","description":"Location Id"}},"required":["path_locationId"]}},{"name":"social-media-posting_get-posts","description":"Retrieves social media posts with advanced filtering and pagination. Supports filtering by post type (recent, all, scheduled, draft, failed, in_review, published, in_progress, deleted), account IDs, date range, and post type (post, story, reel). Returns post list with content, media, status, schedule information, and post metadata. Use this tool when users want to get social media posts, list posts, find posts by status, search posts, filter posts by account, or view scheduled posts. Ideal for post management, content review, post scheduling, and social media content browsing.\n\nCapabilities: get_get-posts\n\nExamples:\n- Use this tool to get posts\n- Endpoint: /social-media-posting/{locationId}/posts/list\n\nSource: default | Team: social-media-posting","inputSchema":{"required":["path_locationId","body_skip","body_limit","body_fromDate","body_toDate","body_includeUsers"],"properties":{"body_postType":{"description":"Post Type must be one of the following values: - post, story, reel","type":"object","example":"post"},"body_fromDate":{"description":"From Date","type":"string","example":"2024-01-22T05:32:49.463Z"},"body_limit":{"example":"10","description":"limit","type":"string"},"body_type":{"example":"Filter type","description":"type must be one of the following values: recent, all, scheduled, draft, failed, in_review, published, in_progress and deleted","type":"string"},"body_toDate":{"description":"To Date","example":"2024-03-20T05:32:49.463Z","type":"string"},"body_accounts":{"example":"660a83fc29deacac50033e2b_omaDY3RbWtTP511e808O_17841465964543589, 38bF83fc29deacac50033e2b_omaDY3RbWtr3P11e808O_17841465964543998","type":"string","description":"List of account Ids seperated by comma as a string"},"body_includeUsers":{"description":"Include User Data","type":"string","example":"true"},"path_locationId":{"description":"Location Id","example":"ve9EPM428h8vShlRW1KT","type":"string"},"body_skip":{"example":"1","description":"skip","type":"string"}},"type":"object"}},{"name":"contacts_get-contacts","description":"Retrieves a list of contacts with pagination support. Supports filtering by location ID, query terms for name/email search, and pagination using startAfter and startAfterId. Returns a list of contacts with basic information. Note: This endpoint is deprecated in favor of the search contacts endpoint. Use this tool when users want to list contacts, get contact list, view all contacts, or browse contacts with pagination. Ideal for contact listing and basic contact browsing scenarios.\n\nCapabilities: get_get-contacts\n\nExamples:\n- Use this tool to get contacts\n- Endpoint: /contacts/\n\nSource: default | Team: contacts","inputSchema":{"properties":{"query_query":{"type":"string","example":"John","description":"Contact Query"},"query_startAfter":{"example":1603870249758,"description":"Start Afte","type":"number"},"query_startAfterId":{"example":"UIaE1WjAwWKdlyD7osQI","type":"string","description":"Start After Id"},"query_locationId":{"type":"string","example":"ve9EPM428h8vShlRW1KT","description":"Location Id"},"query_limit":{"type":"number","example":20,"description":"Limit Per Page records count. will allow maximum up to 100 and default will be 20"}},"type":"object","required":["query_locationId"]}},{"name":"blogs_get-all-blog-authors-by-location","description":"Retrieves all blog authors for a specific location with pagination support. Returns a list of authors including author ID, name, location ID, and canonical link. Supports pagination with limit and offset parameters. Use this tool when users want to get blog authors, list authors, find available authors, or retrieve author information. Ideal for author selection, author management, and blog author lookup scenarios.\n\nCapabilities: get_get-all-blog-authors-by-location\n\nExamples:\n- Use this tool to get all authors\n- Endpoint: /blogs/authors\n\nSource: default | Team: blogs","inputSchema":{"properties":{"query_offset":{"description":"Number of authors to skip in listing","type":"number","example":0},"query_limit":{"description":"Number of authors to show in the listing","example":5,"type":"number"},"query_locationId":{"type":"string","description":"Location Id","example":"ve9EPM428h8vShlRW1KT"}},"required":["query_locationId","query_limit","query_offset"],"type":"object"}},{"name":"conversations_search-conversation","description":"Searches conversations using multiple filters including contact, assigned user, followers, mentions, status, message type, and date range. Supports sorting by last message date or score profile, filtering by conversation status (all, read, unread, starred), and pagination. Returns matching conversations with contact details, last message information, unread count, and conversation metadata. Use this tool when users want to find conversations, search messages, filter conversations by contact, look up conversation history, find unread conversations, or search by assigned user. Ideal for conversation management, message search, communication tracking, and conversation filtering.\n\nCapabilities: search_search-conversation\n\nExamples:\n- Use this tool to search conversations\n- Endpoint: /conversations/search\n\nSource: default | Team: conversations","inputSchema":{"type":"object","properties":{"query_followers":{"description":"User IDs of followers to filter conversations by. Multiple IDs can be provided as comma-separated values.","type":"string","example":"ABCHkzuJQ8ZMd4Te84GK,fGiae4CHkzoskh8thsik"},"query_scoreProfileMin":{"type":"number","description":"Minimum value for score","example":"ABCHkzuJQ8ZMd4Te84GK"},"query_limit":{"description":"Limit of conversations - Default is 20","type":"number","example":20},"query_startAfterDate":{"example":1600854,"description":"Search to begin after the specified date - should contain the sort value of the last document","type":"number"},"query_lastMessageAction":{"type":"string","example":"manual","enum":["automated","manual"],"description":"Action of the last outbound message in the conversation as string."},"query_status":{"enum":["all","read","unread","starred","recents"],"type":"string","description":"The status of the conversation to be filtered - all, read, unread, starred ","example":"all"},"query_id":{"type":"string","example":"ABCHkzuJQ8ZMd4Te84GK","description":"Id of the conversation"},"query_locationId":{"example":"ABCHkzuJQ8ZMd4Te84GK","type":"string","description":"Location Id"},"query_lastMessageType":{"example":"TYPE_SMS","description":"Type of the last message in the conversation as a string","type":"string","enum":["TYPE_CALL","TYPE_SMS","TYPE_EMAIL","TYPE_SMS_REVIEW_REQUEST","TYPE_WEBCHAT","TYPE_SMS_NO_SHOW_REQUEST","TYPE_CAMPAIGN_SMS","TYPE_CAMPAIGN_CALL","TYPE_CAMPAIGN_EMAIL","TYPE_CAMPAIGN_VOICEMAIL","TYPE_FACEBOOK","TYPE_CAMPAIGN_FACEBOOK","TYPE_CAMPAIGN_MANUAL_CALL","TYPE_CAMPAIGN_MANUAL_SMS","TYPE_GMB","TYPE_CAMPAIGN_GMB","TYPE_REVIEW","TYPE_INSTAGRAM","TYPE_WHATSAPP","TYPE_CUSTOM_SMS","TYPE_CUSTOM_EMAIL","TYPE_CUSTOM_PROVIDER_SMS","TYPE_CUSTOM_PROVIDER_EMAIL","TYPE_IVR_CALL","TYPE_ACTIVITY_CONTACT","TYPE_ACTIVITY_INVOICE","TYPE_ACTIVITY_PAYMENT","TYPE_ACTIVITY_OPPORTUNITY","TYPE_LIVE_CHAT","TYPE_LIVE_CHAT_INFO_MESSAGE","TYPE_ACTIVITY_APPOINTMENT","TYPE_FACEBOOK_COMMENT","TYPE_INSTAGRAM_COMMENT","TYPE_CUSTOM_CALL","TYPE_INTERNAL_COMMENT"]},"query_sortBy":{"description":"The sorting of the conversation to be filtered as - manual messages or all messages","example":"last_message_date","enum":["last_manual_message_date","last_message_date","score_profile"],"type":"string"},"query_assignedTo":{"example":"ABCHkzuJQ8ZMd4Te84GK,fGiae4CHkzoskh8thsik","type":"string","description":"User IDs that conversations are assigned to. Multiple IDs can be provided as comma-separated values. Use \"unassigned\" to fetch conversations not assigned to any user."},"query_sortScoreProfile":{"description":"Id of score profile on which sortBy.ScoreProfile should sort on","example":"ABCHkzuJQ8ZMd4Te84GK","type":"string"},"query_scoreProfileMax":{"description":"Maximum value for score","type":"number","example":"ABCHkzuJQ8ZMd4Te84GK"},"query_mentions":{"example":"ABCHkzuJQ8ZMd4Te84GK,fGiae4CHkzoskh8thsik","type":"string","description":"User Id of the mention. Multiple values are comma separated."},"query_lastMessageDirection":{"type":"string","description":"Direction of the last message in the conversation as string.","example":"inbound","enum":["inbound","outbound"]},"query_sort":{"enum":["asc","desc"],"example":"asc","description":"Sort paramater - asc or desc","type":"string"},"query_query":{"example":"Search string","description":"Search paramater as a string","type":"string"},"query_scoreProfile":{"description":"Id of score profile on which conversations should get filtered out, works with scoreProfileMin & scoreProfileMax","type":"string","example":"ABCHkzuJQ8ZMd4Te84GK"},"query_contactId":{"type":"string","example":"9VEmS0si86GW6gXWU89b","description":"Contact Id"}},"required":["query_locationId"]}},{"name":"payments_get-order-by-id","description":"Retrieves detailed information for a specific order using its unique order ID. Returns complete order details including order ID, contact information, currency, amount, status, fulfillment status, order items, payment source, amount summary (subtotal, discount), coupon information, and timestamps. Use this tool when users want to get order details, view order information, see order status, retrieve order data, or look up order by ID. Ideal for order detail viewing, order information retrieval, and order status checking.\n\nCapabilities: get_get-order-by-id\n\nExamples:\n- Use this tool to get order by id\n- Endpoint: /payments/orders/{orderId}\n\nSource: default | Team: payments","inputSchema":{"properties":{"query_altType":{"example":"location","description":"AltType is the type of identifier.","type":"string"},"query_altId":{"example":"3SwdhCu3svxI8AKsPJt6","type":"string","description":"AltId is the unique identifier e.g: location id."},"query_locationId":{"example":"3SwdhCu3svxI8AKsPJt6","description":"LocationId is the id of the sub-account.","type":"string"},"path_orderId":{"example":"653f5e0cde5a1314e62a837c","description":"ID of the order that needs to be returned","type":"string"}},"type":"object","required":["path_orderId","query_altId","query_altType"]}},{"name":"contacts_upsert-contact","description":"Creates a new contact or updates an existing contact based on duplicate detection settings. Uses global unique identifier for de-duplication when duplicate contacts are disabled, or creates a new contact when duplicates are allowed. Accepts complete contact information including name, email, phone, address, company details, tags, and custom fields. Returns the contact record with a flag indicating whether it was newly created or already existed. Use this tool when users want to create or update a contact, ensure contact exists, add contact if missing, or sync contact information. Ideal for contact synchronization, data import workflows, and contact upsert operations.\n\nCapabilities: upsert-contact\n\nExamples:\n- Use this tool to upsert contact\n- Endpoint: /contacts/upsert\n\nSource: default | Team: contacts","inputSchema":{"properties":{"body_phone":{"example":"+1 888-888-8888","description":"phone","nullable":true,"type":"string"},"body_address1":{"description":"address1","type":"string","nullable":true,"example":"3535 1st St N"},"body_tags":{"description":"This field will overwrite all current tags associated with the contact. To update a tags, it is recommended to use the Add Tag or Remove Tag API instead.","example":["nisi sint commodo amet","consequat"],"type":"array","items":{"type":"string"}},"body_assignedTo":{"description":"User's Id","type":"string","example":"y0BeYjuRIlDwsDcOHOJo"},"body_website":{"example":"https://www.tesla.com","type":"string","nullable":true,"description":"website"},"body_dnd":{"example":true,"description":"dnd","type":"boolean"},"body_postalCode":{"example":"35061","description":"postalCode","type":"string"},"body_firstName":{"example":"Rosan","description":"firstName","nullable":true,"type":"string"},"body_state":{"example":"AL","type":"string","description":"state","nullable":true},"body_inboundDndSettings":{"type":"object","description":"inboundDndSettings"},"body_timezone":{"example":"America/Chihuahua","description":"timezone","type":"string","nullable":true},"body_country":{"example":"US","description":"country","type":"string"},"body_customFields":{"description":"customFields","type":"array","items":{"type":"string"}},"body_companyName":{"example":"DGS VolMAX","type":"string","nullable":true,"description":"companyName"},"body_locationId":{"description":"locationId","example":"ve9EPM428h8vShlRW1KT","type":"string"},"body_gender":{"example":"male","description":"gender","type":"string"},"body_lastName":{"example":"Deo","type":"string","nullable":true,"description":"lastName"},"body_dndSettings":{"type":"object","description":"dndSettings"},"body_city":{"example":"Dolomite","type":"string","description":"city","nullable":true},"body_email":{"example":"rosan@deos.com","description":"email","nullable":true,"type":"string"},"body_source":{"type":"string","description":"source","example":"public api"},"body_name":{"description":"name","example":"Rosan Deo","type":"string","nullable":true}},"required":["body_locationId"],"type":"object"}},{"name":"opportunities_search-opportunity","description":"Searches and filters opportunities in the sales pipeline using multiple criteria. Supports filtering by pipeline, pipeline stage, contact, opportunity status (open, won, lost, abandoned), assigned user, campaign, date range, and country. Returns matching opportunities with monetary values, pipeline stage information, contact details, custom fields, notes, tasks, and calendar events. Use this tool when users want to find opportunities, search deals, filter sales pipeline, look up opportunities by contact, find opportunities by stage, query the sales pipeline, or search opportunities by status. Ideal for pipeline management, deal tracking, sales reporting, and opportunity analysis.\n\nCapabilities: search_search-opportunity\n\nExamples:\n- Use this tool to search opportunity\n- Endpoint: /opportunities/search\n\nSource: default | Team: opportunities","inputSchema":{"properties":{"query_getTasks":{"example":false,"description":"get Tasks in contact","type":"boolean"},"query_limit":{"type":"number","description":"Limit Per Page records count. will allow maximum up to 100 and default will be 20"},"query_campaignId":{"example":"Y2I9XM7aO1hncuSOlc9L","description":"Campaign Id","type":"string"},"query_page":{"description":"query_page","type":"number"},"query_date":{"type":"string","example":"mm-dd-yyyy","description":"Start date"},"query_pipeline_id":{"example":"bCkKGpDsyPP4peuKowkG","description":"Pipeline Id","type":"string"},"query_getCalendarEvents":{"description":"get Calender event in contact","example":false,"type":"boolean"},"query_location_id":{"type":"string","example":"i2SpAtBVHSVea1sL6oah","description":"Location Id"},"query_status":{"enum":["open","won","lost","abandoned","all"],"type":"string","description":"query_status"},"query_q":{"example":"john@deo.com","description":"query_q","type":"string"},"query_country":{"type":"string","example":"US","description":"query_country"},"query_startAfter":{"description":"Start After","example":"1628008053263","type":"string"},"query_pipeline_stage_id":{"example":"7915dedc-8f18-44d5-8bc3-77c04e994a10","description":"stage Id","type":"string"},"query_assigned_to":{"type":"string","example":"082goXVW3lIExEQPOnd3","description":"query_assigned_to"},"query_startAfterId":{"example":"UIaE1WjAwWKdlyD7osQI","description":"Start After Id","type":"string"},"query_order":{"description":"query_order","example":"added_asc","type":"string"},"query_id":{"example":"123akv4LFn6C9frZoy3e","type":"string","description":"Opportunity Id"},"query_contact_id":{"type":"string","example":"WFwVrSSjZ2CNHbZThQX2","description":"Contact Id"},"query_getNotes":{"example":false,"description":"get Notes in contact","type":"boolean"},"query_endDate":{"description":"End date","example":"mm-dd-yyyy","type":"string"}},"required":["query_location_id"],"type":"object"}},{"name":"calendars_get-appointment-notes","description":"Retrieves notes associated with a specific appointment. Returns a paginated list of notes including note ID, body, user ID, creation date, and creator information. Supports pagination with limit and offset parameters. Use this tool when users want to view appointment notes, get appointment notes, see notes for an appointment, or retrieve appointment note history. Ideal for appointment note review, note management, and appointment documentation lookup.\n\nCapabilities: get_get-appointment-notes\n\nExamples:\n- Use this tool to get notes\n- Endpoint: /calendars/appointments/{appointmentId}/notes\n\nSource: default | Team: calendars","inputSchema":{"properties":{"query_offset":{"example":0,"description":"Offset of notes to fetch","type":"number"},"query_limit":{"type":"number","example":10,"description":"Limit of notes to fetch"},"path_appointmentId":{"description":"Appointment ID","type":"string"}},"type":"object","required":["query_limit","query_offset","path_appointmentId"]}},{"name":"payments_list-transactions","description":"Retrieves a paginated list of transactions with comprehensive filtering options. Supports filtering by payment mode, date range, transaction source type and subtype, contact, subscription ID, entity ID, and search terms. Returns transaction list with amount, status, payment method, contact information, entity details, charge information, and timestamps. Use this tool when users want to list transactions, get transaction history, filter transactions, search transactions, find transactions by contact, or view payment transactions. Ideal for transaction management, payment tracking, financial reporting, and transaction analysis.\n\nCapabilities: list_list-transactions\n\nExamples:\n- Use this tool to list transactions\n- Endpoint: /payments/transactions\n\nSource: default | Team: payments","inputSchema":{"required":["query_altId","query_altType"],"properties":{"query_endAt":{"description":"Closing interval of transactions.","example":"2024-02-13","type":"string"},"query_paymentMode":{"example":"live","description":"Mode of payment.","type":"string"},"query_search":{"description":"The name of the transaction for searching.","example":"Awesome transaction","type":"string"},"query_startAt":{"example":"2024-02-01","description":"Starting interval of transactions.","type":"string"},"query_subscriptionId":{"example":"sub_1KGcXDCScnf89tZoVkoEMCEL","description":"Subscription id for filtering of transactions.","type":"string"},"query_entitySourceSubType":{"type":"string","example":"two_step_order_form","description":"Source sub-type of the transactions."},"query_limit":{"description":"The maximum number of items to be included in a single page of results","example":20,"type":"number"},"query_locationId":{"type":"string","example":"3SwdhCu3svxI8AKsPJt6","description":"LocationId is the id of the sub-account."},"query_altType":{"description":"AltType is the type of identifier.","type":"string","example":"location"},"query_contactId":{"example":"XPLSw2SVagl12LMDeTmQ","type":"string","description":"Contact id for filtering of transactions."},"query_offset":{"example":0,"description":"The starting index of the page, indicating the position from which the results should be retrieved.","type":"number"},"query_entityId":{"example":"61dd0fe9c077f73e67f78803","description":"Entity id for filtering of transactions.","type":"string"},"query_entitySourceType":{"example":"funnel","type":"string","description":"Source of the transactions."},"query_altId":{"type":"string","description":"AltId is the unique identifier e.g: location id.","example":"3SwdhCu3svxI8AKsPJt6"}},"type":"object"}},{"name":"social-media-posting_get-social-media-statistics","description":"Retrieve analytics data for multiple social media accounts. Provides metrics for the last 7 days with comparison to the previous 7 days. Supports filtering by platforms and specific connected accounts.\n\nCapabilities: get_get-social-media-statistics\n\nExamples:\n- Use this tool to get social media statistics\n- Endpoint: /social-media-posting/statistics\n\nSource: default | Team: social-media-posting","inputSchema":{"required":["query_locationId","body_profileIds"],"type":"object","properties":{"query_locationId":{"example":"w37swmmLbA02zgqKPpxITe2","type":"string","description":"Location ID"},"body_platforms":{"example":["facebook","instagram"],"description":"Array of social media platforms to filter analytics by. If not provided, all platforms will be included. NOTE: Linkedin (PAGE only) and Tiktok (BUSINESS only) are supported.","type":"array","items":{"enum":["facebook","instagram","linkedin","google","pinterest","youtube","tiktok"],"type":"string"}},"body_profileIds":{"example":["67a5a9aa776c837de4aa5b12"],"description":"Array of connected social media account IDs to fetch analytics for. This can be found as 'profileId' in /accounts api.","type":"array","items":{"type":"string"}}}}},{"name":"emails_fetch-template","description":"Retrieves email templates for a location with advanced filtering and pagination. Supports filtering by name, parent folder, builder version, archived status, search terms, and sorting by date. Returns template list with name, ID, type, last updated date, preview URL, and template metadata. Use this tool when users want to get email templates, list templates, find email template, search templates, or browse email templates. Ideal for template listing, template search, template management, and email template discovery.\n\nCapabilities: fetch_fetch-template\n\nExamples:\n- Use this tool to fetch email templates\n- Endpoint: /emails/builder\n\nSource: default | Team: emails","inputSchema":{"properties":{"query_search":{"description":"query_search","type":"string"},"query_limit":{"type":"string","description":"query_limit"},"query_templatesOnly":{"description":"query_templatesOnly","type":"string"},"query_originId":{"example":"ve9EPM428h8vShlRW1KT","type":"string","description":"query_originId"},"query_name":{"description":"query_name","type":"string"},"query_archived":{"type":"string","description":"query_archived"},"query_sortByDate":{"description":"query_sortByDate","type":"string"},"query_offset":{"description":"query_offset","type":"string"},"query_locationId":{"type":"string","example":"ve9EPM428h8vShlRW1KT","description":"query_locationId"},"query_parentId":{"description":"query_parentId","type":"string"},"query_builderVersion":{"type":"string","description":"query_builderVersion","enum":["1","2"]}},"type":"object","required":["query_locationId"]}},{"name":"blogs_get-blogs","description":"Retrieves a list of blog sites for a location with pagination and search support. Returns blog sites with their IDs and names. Supports filtering by search terms and pagination with skip and limit parameters. Use this tool when users want to list blog sites, get all blogs, find blog sites, or browse available blogs. Ideal for blog site discovery, blog management, and blog site listing scenarios.\n\nCapabilities: get_get-blogs\n\nExamples:\n- Use this tool to get blogs by location id\n- Endpoint: /blogs/site/all\n\nSource: default | Team: blogs","inputSchema":{"required":["query_locationId","query_skip","query_limit"],"type":"object","properties":{"query_search