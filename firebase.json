{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "destination": "https://rora-backend-rora-app-d98e6-uc.a.run.app"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
